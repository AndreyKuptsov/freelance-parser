{
  "_comment": "Скопируйте этот файл в config.json и заполните своими данными",
  
  "telegram_bot_token": "YOUR_BOT_TOKEN_HERE",
  "telegram_chat_id": "YOUR_CHAT_ID_HERE",
  
  "enable_fl_ru": true,
  "fl_ru_login": "your_fl_ru_login",
  "fl_ru_password": "your_fl_ru_password",
  "fl_ru_categories": ["", "programming", "web-programming"],
  
  "enable_freelance_ru": false,
  "freelance_ru_login": "your_freelance_ru_login",
  "freelance_ru_password": "your_freelance_ru_password",
  
  "auto_send_proposals": false,
  "check_interval": 300,
  "delay_between_proposals": 10,
  
  "keywords": [
    "python",
    "javascript",
    "typescript",
    "node",
    "react",
    "vue",
    "angular",
    "fastapi",
    "django",
    "flask",
    "telegram",
    "telegram bot",
    "telegram mini app",
    "flutter",
    "dart",
    "парсинг",
    "автоматизация",
    "бот",
    "api",
    "веб-разработка",
    "мобильное приложение",
    "backend",
    "frontend",
    "fullstack",
    "scraping",
    "crawler"
  ],
  
  "exclude_keywords": [
    "дизайн логотипа",
    "баннер",
    "копирайтинг",
    "рерайтинг",
    "seo продвижение",
    "контент-менеджер",
    "набор текста",
    "перевод",
    "озвучка",
    "видеомонтаж",
    "фотошоп",
    "иллюстрация",
    "3d модель",
    "анимация",
    "сеньор",
    "senior",
    "опытный разработчик",
    "5+ лет опыта",
    "от 5 лет",
    "только опытные"
  ],
  
  "min_budget": 3000,
  
  "default_price": "10000",
  "default_deadline": "7 дней",
  
  "proposal_template": "Здравствуйте, {client_name}!\n\nЗаинтересовало ваше задание \"{title}\".\n\nИмею большой опыт работы с подобными проектами. Готов выполнить работу качественно и в срок.\n\nПредлагаемый бюджет: {budget}\nСрок выполнения: 7 дней\n\nГотов обсудить детали проекта и ответить на все ваши вопросы.\n\nС уважением"
}
